@page
@model SettingsModel
@{
    ViewData["Title"] = "Налаштування";
}

<div class="page-header">
    <span class="page-icon"><i class="bi bi-gear"></i></span>
    <h1>Налаштування</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    .pipeline-diagram {
        max-width: 560px;
        margin: 0 auto;
    }

    .pipe-node {
        border: 1px solid var(--bs-border-color);
        border-radius: .5rem;
        padding: .5rem .75rem;
        background: var(--bs-body-bg);
        cursor: pointer;
        transition: box-shadow .15s, border-color .15s, opacity .15s;
    }

    .pipe-node:hover {
        box-shadow: 0 0 0 .15rem rgba(13, 110, 253, .2);
        border-color: #0d6efd;
    }

    .pipe-node.is-disabled {
        opacity: .55;
        border-style: dashed;
    }

    .pipe-node-title {
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .pipe-node-sub {
        font-size: .75rem;
        color: var(--bs-secondary-color);
        margin-top: .15rem;
    }

    .pipe-note {
        font-size: .7rem;
        color: #dc3545;
        margin-top: .15rem;
    }

    .pipe-badge-bypass {
        font-size: .7rem;
        color: #fd7e14;
        margin-top: .25rem;
    }

    .pipe-status-dot {
        width: .55rem;
        height: .55rem;
        border-radius: 50%;
        background: #6c757d;
        display: inline-block;
    }

    .pipe-node:not(.is-disabled) .pipe-status-dot {
        background: #198754;
    }

    .pipe-node-status {
        color: var(--bs-secondary-color);
    }

    .pipe-arrow {
        display: flex;
        justify-content: center;
        color: var(--bs-secondary-color);
        padding: .1rem 0;
    }

    .pipe-split-label {
        text-align: center;
        font-size: .8rem;
        color: var(--bs-secondary-color);
        margin: .1rem 0 .5rem;
    }

    .pipe-actions-row {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .pipe-actions-row .pipe-node {
        flex: 1 1 220px;
    }

    .pipe-highlight {
        box-shadow: 0 0 0 .25rem rgba(13, 110, 253, .35) !important;
    }
</style>

@{
    var bypassCount = Model.Pipeline.TransformClassificationBypass
        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
    var blockCount = Model.Pipeline.TransformClassificationBlock
        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
}

@* ── Pipeline diagram ── *@
<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-diagram-3"></i> Pipeline обробки тендера</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Натисніть на елемент, щоб перейти до відповідних налаштувань. Стан (увімкнено/вимкнено)
            оновлюється одразу при перемиканні перемикачів нижче — форму зберігати не обов'язково для перегляду.
        </p>
        <div class="pipeline-diagram">

            <div class="pipe-node pipe-node--source" data-target="card-global">
                <div class="pipe-node-title"><i class="bi bi-cloud-download"></i> Джерело: OpenProcurement API</div>
                <div class="pipe-node-sub">Стартове вікно: −@Model.Pipeline.Subtract год. від поточного часу</div>
            </div>
            <div class="pipe-arrow"><i class="bi bi-arrow-down"></i></div>

            <div class="pipe-node pipe-node--filter" data-target="card-status"
                 data-checkbox="Pipeline_TransformStatusEnabled">
                <div class="pipe-node-title">
                    <i class="bi bi-funnel"></i> Фільтр: статус тендера
                    <span class="pipe-status-dot ms-auto"></span>
                    <span class="pipe-node-status small"></span>
                </div>
                <div class="pipe-node-sub">Дозволено статусів: @Model.SelectedStatuses.Count</div>
                <div class="pipe-note">інакше — відхилено</div>
            </div>
            <div class="pipe-arrow"><i class="bi bi-arrow-down"></i></div>

            <div class="pipe-node pipe-node--filter" data-target="card-classification"
                 data-checkbox="Pipeline_TransformClassificationEnabled">
                <div class="pipe-node-title">
                    <i class="bi bi-funnel"></i> Фільтр: класифікація (CPV)
                    <span class="pipe-status-dot ms-auto"></span>
                    <span class="pipe-node-status small"></span>
                </div>
                <div class="pipe-node-sub">Bypass: @bypassCount код(и) · Block: @blockCount код(и)</div>
                <div class="pipe-note">Block-коди — відхилено</div>
                <div class="pipe-badge-bypass"><i class="bi bi-arrow-return-right"></i> Bypass-коди минають фільтр
                    «Організація» нижче</div>
                </div>
                <div class="pipe-arrow"><i class="bi bi-arrow-down"></i></div>

                <div class="pipe-node pipe-node--filter" data-target="card-identifier"
                     data-checkbox="Pipeline_TransformIdentifierEnabled">
                    <div class="pipe-node-title">
                        <i class="bi bi-funnel"></i> Фільтр: організація (Procuring Entity)
                        <span class="pipe-status-dot ms-auto"></span>
                        <span class="pipe-node-status small"></span>
                    </div>
                    <div class="pipe-node-sub">Пропускає лише організації зі списку Procuring Entity</div>
                    <div class="pipe-note">інакше — відхилено</div>
                </div>
                <div class="pipe-arrow"><i class="bi bi-arrow-down"></i></div>

                <div class="pipe-node pipe-node--filter" data-target="card-tenderhistory-filter"
                     data-checkbox="Pipeline_TransformTendersHistoryEnabled">
                    <div class="pipe-node-title">
                        <i class="bi bi-clock-history"></i> Фільтр: історія тендерів
                        <span class="pipe-status-dot ms-auto"></span>
                        <span class="pipe-node-status small"></span>
                    </div>
                    <div class="pipe-node-sub">Пропускає тільки тендери, яких ще немає в історії</div>
                    <div class="pipe-note">вже в історії — відхилено</div>
                </div>
                <div class="pipe-arrow"><i class="bi bi-arrow-down"></i></div>

                <div class="pipe-split-label"><i class="bi bi-arrow-down-up"></i> Паралельно виконуються дві дії:</div>

                <div class="pipe-actions-row">
                    <div class="pipe-node pipe-node--action" data-target="card-tenderhistory-action"
                         data-checkbox="Pipeline_ActionTendersHistoryEnabled">
                        <div class="pipe-node-title">
                            <i class="bi bi-lightning-charge"></i> Дія: зберегти в історію
                            <span class="pipe-status-dot ms-auto"></span>
                            <span class="pipe-node-status small"></span>
                        </div>
                    </div>
                    <div class="pipe-node pipe-node--action" data-target="card-sendmail" data-checkbox="Settings_Enabled">
                        <div class="pipe-node-title">
                            <i class="bi bi-envelope"></i> Дія: надіслати email
                            <span class="pipe-status-dot ms-auto"></span>
                            <span class="pipe-node-status small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form method="post" id="settingsForm">
        @* ── Global ── *@
        <div class="card mb-3" id="card-global">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-sliders"></i> Загальні</h5>
            </div>
            <div class="card-body">
                <label class="form-label">Зсув старту від поточного часу (годин)</label>
                <input asp-for="Pipeline.Subtract" class="form-control form-control-sm" type="number"
                       style="max-width: 150px;" />
                <small class="text-muted">Скільки годин назад від зараз брати тендери при старті.</small>
            </div>
        </div>

        @* ── Transform:Status ── *@
        <div class="card mb-3" id="card-status">
            <div class="card-header">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Pipeline.TransformStatusEnabled" />
                    <label class="form-check-label fw-semibold" asp-for="Pipeline.TransformStatusEnabled">
                        <i class="bi bi-funnel"></i> Фільтр: дозволені статуси тендера
                    </label>
                </div>
            </div>
            <div class="card-body">
                <label class="form-label small text-muted">Оберіть статуси зі списку</label>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-1 mb-2" id="statusChecklist">
                    @foreach (var status in SettingsModel.KnownTenderStatuses)
                    {
                        <div class="col">
                            <div class="form-check">
                                <input class="form-check-input status-checkbox" type="checkbox" name="SelectedStatuses"
                                       value="@status.Value" id="status_@status.Value.Replace('.', '_')"
                                       checked="@(Model.SelectedStatuses.Contains(status.Value) ? "checked" : null)" />
                                <label class="form-check-label small" for="status_@status.Value.Replace('.', '_')"
                                       title="@status.Description">
                                    <code class="small">@status.Value</code> — @status.Description
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Transform:Classification ── *@
        <div class="card mb-3" id="card-classification">
            <div class="card-header">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Pipeline.TransformClassificationEnabled" />
                    <label class="form-check-label fw-semibold" asp-for="Pipeline.TransformClassificationEnabled">
                        <i class="bi bi-funnel"></i> Фільтр: класифікація (CPV)
                    </label>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Пропустити коди (по одному на рядок)</label>
                        <textarea asp-for="Pipeline.TransformClassificationBypass" class="form-control form-control-sm"
                                  rows="4" placeholder="64220000-4"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Заблоковані коди (по одному на рядок)</label>
                        <textarea asp-for="Pipeline.TransformClassificationBlock" class="form-control form-control-sm"
                                  rows="4" placeholder="09130000-9"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* ── Transform:Identifier ── *@
        <div class="card mb-3" id="card-identifier">
            <div class="card-header">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Pipeline.TransformIdentifierEnabled" />
                    <label class="form-check-label fw-semibold" asp-for="Pipeline.TransformIdentifierEnabled">
                        <i class="bi bi-funnel"></i> Фільтр: тільки організації зі списку Procuring Entity
                    </label>
                </div>
            </div>
        </div>

        @* ── Transform:TendersHistory ── *@
        <div class="card mb-3" id="card-tenderhistory-filter">
            <div class="card-header">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Pipeline.TransformTendersHistoryEnabled" />
                    <label class="form-check-label fw-semibold" asp-for="Pipeline.TransformTendersHistoryEnabled">
                        <i class="bi bi-funnel"></i> Фільтр: пропускати тендери, яких немає в історії
                    </label>
                </div>
            </div>
        </div>

        @* ── Action:TendersHistory ── *@
        <div class="card mb-3" id="card-tenderhistory-action">
            <div class="card-header">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Pipeline.ActionTendersHistoryEnabled" />
                    <label class="form-check-label fw-semibold" asp-for="Pipeline.ActionTendersHistoryEnabled">
                        <i class="bi bi-lightning-charge"></i> Дія: зберігати історію тендерів
                    </label>
                </div>
            </div>
        </div>

        @* ── Action:SendMail ── *@
        <div class="card mb-3" id="card-sendmail">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" asp-for="Settings.Enabled" />
                    <label class="form-check-label fw-semibold" asp-for="Settings.Enabled">
                        <i class="bi bi-lightning-charge"></i> Дія: відправка пошти
                    </label>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetTemplate()"
                        title="Скинути шаблон до значення за замовчуванням">
                    <i class="bi bi-arrow-counterclockwise"></i> Скинути шаблон
                </button>
            </div>
            <div class="card-body">
                <div class="row mb-2 g-2">
                    <div class="col-md-6">
                        <label class="form-label">Відправник</label>
                        <input asp-for="Settings.From" class="form-control form-control-sm"
                               placeholder="Tenders Agent <sender@corp-mail.com>" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Тема листа</label>
                        <input asp-for="Settings.Subject" class="form-control form-control-sm"
                               placeholder="%Value.String% - %Title% - (%ProcuringEntity.Name%)" />
                    </div>
                </div>

                <div class="row mb-2 g-2">
                    <div class="col-md-6">
                        <label class="form-label">Сервер SMTP</label>
                        <input asp-for="Settings.Server" class="form-control form-control-sm"
                               placeholder="smtp.server.com" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Порт</label>
                        <input asp-for="Settings.Port" class="form-control form-control-sm" type="number" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="Settings.EnableSsl" />
                            <label class="form-check-label" asp-for="Settings.EnableSsl">SSL</label>
                        </div>
                    </div>
                </div>

                <div class="row mb-2 g-2">
                    <div class="col-md-6">
                        <label class="form-label">Користувач (SMTP)</label>
                        <input asp-for="Settings.Username" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Пароль</label>
                        <input asp-for="Settings.Password" class="form-control form-control-sm" type="password"
                               autocomplete="new-password" placeholder="Залиште порожнім, щоб не змінювати" />
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label">Одержувачі <span class="text-muted small">(по одному на рядок)</span></label>
                    <textarea asp-for="Settings.MailTo" class="form-control form-control-sm" rows="3"
                              placeholder="user@corp-mail.com&#10;user1@corp-mail.com"></textarea>
                </div>

                <div class="mb-2">
                    <label class="form-label">Шаблон листа (HTML)</label>
                    <textarea asp-for="Settings.MessageTemplate" class="form-control font-monospace" rows="12"
                              style="font-size: 12px;"></textarea>
                    <small class="text-muted">Використовуйте <code>%body%</code> для вставки вмісту листа.</small>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" asp-page-handler="Save" class="btn btn-primary">
                <i class="bi bi-save"></i> Зберегти
            </button>
        </div>
    </form>

    <form method="post" asp-page-handler="ResetTemplate" id="resetTemplateForm" class="d-none"></form>

    @section Scripts {
        <script>
            function resetTemplate() {
                if (confirm('Скинути шаблон листа до значення за замовчуванням?')) {
                    document.getElementById('resetTemplateForm').submit();
                }
            }

            // Pipeline diagram: live enabled/disabled state + click-to-scroll navigation
            document.querySelectorAll('.pipe-node[data-checkbox]').forEach(function (node) {
                var checkbox = document.getElementById(node.getAttribute('data-checkbox'));
                if (!checkbox) return;

                var statusEl = node.querySelector('.pipe-node-status');
                function sync() {
                    var on = checkbox.checked;
                    node.classList.toggle('is-disabled', !on);
                    if (statusEl) statusEl.textContent = on ? 'Увімкнено' : 'Вимкнено';
                }
                checkbox.addEventListener('change', sync);
                sync();
            });

            document.querySelectorAll('.pipe-node[data-target]').forEach(function (node) {
                node.addEventListener('click', function () {
                    var target = document.getElementById(node.getAttribute('data-target'));
                    if (!target) return;
                    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    target.classList.add('pipe-highlight');
                    setTimeout(function () { target.classList.remove('pipe-highlight'); }, 1500);
                });
            });
        </script>
    }

